# 示例：前置反向代理，对 /server/* 与 /worker/* 做 IP 白名单访问控制。
#
# 背景：/server/* (PowerJob 协议)与 /worker/* (简化 http 协议)端点均无鉴权(靠 appName 归属 +
# 网络隔离)，任何人可调用 workerHeartbeat 注册任意 worker 地址 → 到期 job 主动 POST 该地址(SSRF)，
# reportInstanceStatus / 回报 status 可伪造实例状态。生产部署必须让这两组端点仅对 worker 来源网段
# 开放，切勿暴露公网。/api/* 自带登录会话鉴权，可正常暴露。
#
# 用法：geo 块放入 nginx.conf 的 http{}；server 块为本片段。置于 tp-job 前端，
# 监听 80/443，proxy_pass 到上游 tp-job:8080。

# ---- 放入 http{} ----
# 按实际 worker 部署网段修改 allow 规则
geo $worker_allowed {
    default        0;
    10.0.0.0/8     1;   # 示例：允许内网 worker 网段
    172.16.0.0/12  1;
    192.168.0.0/16 1;
}

# ---- server 块 ----
server {
    listen 80;
    server_name _;

    # worker 协议端点(/server/* 与 /worker/*)：仅放行可信 worker 网段
    location ~ ^/(server|worker)/ {
        if ($worker_allowed = 0) {
            return 403;
        }
        proxy_pass http://tp-job:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # 管理 API(自带登录会话鉴权)+ 管理台静态资源
    location / {
        proxy_pass http://tp-job:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
